# API
API_PORT=3000
NODE_ENV=development

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=wsspy
MYSQL_USER=wsspy
MYSQL_PASSWORD=wsspy

# Prisma (inside Docker network)
DATABASE_URL=mysql://wsspy:wsspy@mysql:3306/wsspy

# Prisma (local dev outside Docker)
# DATABASE_URL=mysql://wsspy:wsspy@localhost:3306/wsspy

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b

# WhatsApp sessions
SESSIONS_PATH=/data/sessions

# Desktop (Electron renderer)
API_URL=http://localhost:3000
