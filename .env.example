# API
API_PORT=3000
NODE_ENV=development

# Auth (F02)
# CAMBIAR en produccion. Ejemplo: openssl rand -hex 32
JWT_SECRET=dev-secret-please-change
JWT_EXPIRES_IN=7d
LINK_CODE_TTL_MIN=15

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=wsspy
MYSQL_USER=wsspy
MYSQL_PASSWORD=wsspy

# Prisma (local dev: API fuera de Docker → localhost)
DATABASE_URL=mysql://wsspy:wsspy@localhost:3306/wsspy

# Prisma (solo si la API corre dentro de docker-compose)
# DATABASE_URL=mysql://wsspy:wsspy@mysql:3306/wsspy

# Ollama (local dev)
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
# Alternativa más liviana (peor calidad de JSON en castellano):
# OLLAMA_MODEL=gemma3:1b

# AI worker (F01: detección automática)
AI_CONTEXT_WINDOW=15
AI_WORKER_INTERVAL_MS=5000
AI_WORKER_BATCH_SIZE=5

# WhatsApp sessions
SESSIONS_PATH=/data/sessions

# Desktop (Electron renderer)
API_URL=http://localhost:3000
