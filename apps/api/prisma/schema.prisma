generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Device {
  id              String           @id @default(cuid())
  label           String
  phoneE164       String?
  status          DeviceStatus     @default(DISCONNECTED)
  sessionPath     String           @unique
  createdAt       DateTime         @default(now())
  contacts        Contact[]
  conversations   Conversation[]
  monitoredGroups MonitoredGroup[]
}

model Contact {
  id            String         @id @default(cuid())
  deviceId      String?
  device        Device?        @relation(fields: [deviceId], references: [id])
  phoneE164     String
  displayName   String
  pushName      String?
  notes         String?        @db.Text
  isManual      Boolean        @default(false)
  tasks         Task[]
  conversations Conversation[]

  @@unique([deviceId, phoneE164])
}

model Conversation {
  id            String         @id @default(cuid())
  deviceId      String
  contactId     String?
  jid           String
  title         String?
  lastMessageAt DateTime?
  messages      Message[]
  device        Device         @relation(fields: [deviceId], references: [id])
  contact       Contact?       @relation(fields: [contactId], references: [id])
  proposals     TaskProposal[]

  @@unique([deviceId, jid])
}

model Message {
  id             String         @id @default(cuid())
  conversationId String
  externalId     String
  fromMe         Boolean
  text           String?        @db.Text
  mediaUrl       String?
  sentAt         DateTime
  conversation   Conversation   @relation(fields: [conversationId], references: [id])
  analysisQueue  AnalysisQueue?
  proposal       TaskProposal?

  @@unique([conversationId, externalId])
}

model Task {
  id          String     @id @default(cuid())
  contactId   String
  title       String
  description String?    @db.Text
  status      TaskStatus @default(PENDING)
  dueAt       DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  contact     Contact    @relation(fields: [contactId], references: [id])
}

model AiAnalysis {
  id        String   @id @default(cuid())
  scope     String
  refId     String
  model     String
  output    Json
  createdAt DateTime @default(now())
}

model AnalysisQueue {
  id          String      @id @default(cuid())
  messageId   String      @unique
  message     Message     @relation(fields: [messageId], references: [id])
  status      QueueStatus @default(PENDING)
  attempts    Int         @default(0)
  lastError   String?     @db.Text
  enqueuedAt  DateTime    @default(now())
  processedAt DateTime?

  @@index([status, enqueuedAt])
}

model TaskProposal {
  id                  String         @id @default(cuid())
  creatorUserId       String?
  sourceMessageId     String         @unique
  sourceMessage       Message        @relation(fields: [sourceMessageId], references: [id])
  conversationId      String
  conversation        Conversation   @relation(fields: [conversationId], references: [id])
  titulo              String         @db.VarChar(500)
  descripcion         String?        @db.Text
  fechaLimite         DateTime?
  categoria           String         @db.VarChar(50)
  responsableProbable String?        @db.VarChar(200)
  confianza           Float
  status              ProposalStatus @default(PENDIENTE)
  rawOutput           Json
  modelUsed           String         @db.VarChar(100)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([conversationId])
}

enum DeviceStatus {
  DISCONNECTED
  CONNECTING
  QR_READY
  CONNECTED
  ERROR
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum QueueStatus {
  PENDING
  PROCESSING
  DONE
  SKIPPED
  ERROR
}

enum ProposalStatus {
  PENDIENTE
  APROBADA
  DESCARTADA
  RETENIDA
}

model MonitoredGroup {
  id              String   @id @default(cuid())
  deviceId        String
  device          Device   @relation(fields: [deviceId], references: [id])
  jid             String
  title           String?
  addedByUserId   String?
  addedAt         DateTime @default(now())

  @@unique([deviceId, jid])
  @@index([deviceId])
}
