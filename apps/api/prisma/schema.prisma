generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Device {
  id              String           @id @default(cuid())
  label           String
  phoneE164       String?
  status          DeviceStatus     @default(DISCONNECTED)
  sessionPath     String           @unique
  createdAt       DateTime         @default(now())
  contacts        Contact[]
  conversations   Conversation[]
  monitoredGroups MonitoredGroup[]
}

model Contact {
  id            String         @id @default(cuid())
  deviceId      String?
  device        Device?        @relation(fields: [deviceId], references: [id])
  phoneE164     String
  displayName   String
  pushName      String?
  notes         String?        @db.Text
  isManual      Boolean        @default(false)
  tasks         Task[]
  conversations Conversation[]

  @@unique([deviceId, phoneE164])
}

model Conversation {
  id            String         @id @default(cuid())
  deviceId      String
  contactId     String?
  jid           String
  title         String?
  lastMessageAt DateTime?
  messages      Message[]
  device        Device         @relation(fields: [deviceId], references: [id])
  contact       Contact?       @relation(fields: [contactId], references: [id])
  proposals     TaskProposal[]

  @@unique([deviceId, jid])
}

model Message {
  id             String         @id @default(cuid())
  conversationId String
  externalId     String
  fromMe         Boolean
  text           String?        @db.Text
  mediaUrl       String?
  sentAt         DateTime
  senderJid      String?
  conversation   Conversation   @relation(fields: [conversationId], references: [id])
  analysisQueue  AnalysisQueue?
  proposal       TaskProposal?

  @@unique([conversationId, externalId])
  @@index([senderJid])
}

model Task {
  id               String        @id @default(cuid())
  contactId        String?
  contact          Contact?      @relation(fields: [contactId], references: [id])
  assigneeUserId   String?
  assignee         User?         @relation("AssignedTasks", fields: [assigneeUserId], references: [id])
  createdByUserId  String?
  createdBy        User?         @relation("CreatedTasks", fields: [createdByUserId], references: [id])
  sourceProposalId String?       @unique
  sourceProposal   TaskProposal? @relation(fields: [sourceProposalId], references: [id])
  title            String
  description      String?       @db.Text
  category         String?       @db.VarChar(50)
  status           TaskStatus    @default(PENDING)
  dueAt            DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([assigneeUserId])
  @@index([status])
}

model AiAnalysis {
  id        String   @id @default(cuid())
  scope     String
  refId     String
  model     String
  output    Json
  createdAt DateTime @default(now())
}

model AnalysisQueue {
  id          String      @id @default(cuid())
  messageId   String      @unique
  message     Message     @relation(fields: [messageId], references: [id])
  status      QueueStatus @default(PENDING)
  attempts    Int         @default(0)
  lastError   String?     @db.Text
  enqueuedAt  DateTime    @default(now())
  processedAt DateTime?

  @@index([status, enqueuedAt])
}

model TaskProposal {
  id                    String         @id @default(cuid())
  creatorUserId         String?
  creator               User?          @relation("ProposalsCreated", fields: [creatorUserId], references: [id])
  matchedAssigneeUserId String?
  matchedAssignee       User?          @relation("ProposalsMatched", fields: [matchedAssigneeUserId], references: [id])
  sourceMessageId       String         @unique
  sourceMessage         Message        @relation(fields: [sourceMessageId], references: [id])
  conversationId        String
  conversation          Conversation   @relation(fields: [conversationId], references: [id])
  titulo                String         @db.VarChar(500)
  descripcion           String?        @db.Text
  fechaLimite           DateTime?
  categoria             String         @db.VarChar(50)
  responsableProbable   String?        @db.VarChar(200)
  confianza             Float
  status                ProposalStatus @default(PENDIENTE)
  rawOutput             Json
  modelUsed             String         @db.VarChar(100)
  resultingTask         Task?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([conversationId])
  @@index([creatorUserId, status])
}

enum DeviceStatus {
  DISCONNECTED
  CONNECTING
  QR_READY
  CONNECTED
  ERROR
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum QueueStatus {
  PENDING
  PROCESSING
  DONE
  SKIPPED
  ERROR
}

enum ProposalStatus {
  PENDIENTE
  APROBADA
  DESCARTADA
  RETENIDA
}

model MonitoredGroup {
  id              String   @id @default(cuid())
  deviceId        String
  device          Device   @relation(fields: [deviceId], references: [id])
  jid             String
  title           String?
  addedByUserId   String?
  addedBy         User?    @relation("AddedBy", fields: [addedByUserId], references: [id])
  addedAt         DateTime @default(now())

  @@unique([deviceId, jid])
  @@index([deviceId])
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  passwordHash     String
  displayName      String
  role             Role             @default(MEMBER)
  phoneE164        String?          @unique
  createdAt        DateTime         @default(now())
  linkCodes        LinkCode[]
  proposalsCreated TaskProposal[]   @relation("ProposalsCreated")
  proposalsMatched TaskProposal[]   @relation("ProposalsMatched")
  tasksAssigned    Task[]           @relation("AssignedTasks")
  tasksCreated     Task[]           @relation("CreatedTasks")
  groupsAdded      MonitoredGroup[] @relation("AddedBy")
}

model LinkCode {
  id          String    @id @default(cuid())
  code        String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  expiresAt   DateTime
  consumedAt  DateTime?
  consumedJid String?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt, consumedAt])
}

enum Role {
  ADMIN
  MEMBER
}
